rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the user authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is this the owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: is the requester an admin
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Carts
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Orders — any authenticated user can create/read; admin can delete
    match /orders/{orderId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // Wishlists
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Saved addresses
    match /user_addresses/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Payment preferences
    match /user_payments/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User behavior (AI recommendations)
    match /user_behavior/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Reviews — public read, authenticated write, owner can edit/delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
    }

    // Returns
    match /returns/{returnId} {
      allow read, create, update: if isAuth();
      match /messages/{msgId} {
        allow read, create: if isAuth();
      }
    }

    // Support tickets — user can create/read their own; admin full access
    match /support_tickets/{ticketId} {
      allow read, create, update: if isAuth();
      match /messages/{msgId} {
        allow read, create: if isAuth();
      }
    }

    // Product Q&A — public read, authenticated ask, verified/admin answer
    match /product_qa/{questionId} {
      allow read: if true;
      allow create: if isAuth();
      match /answers/{answerId} {
        allow read: if true;
        allow create: if isAuth();
      }
    }

    // Daily deal override — public read, admin write
    match /daily_deal/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Product presence (real-time viewers)
    match /product_presence/{productId} {
      allow read, write: if isAuth();
    }

    // Inventory — public read, admin write
    match /inventory/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products catalogue — public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
