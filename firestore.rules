rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Users
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAuth();
    }

    // Carts
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Orders
    match /orders/{orderId} {
      allow read, create, update: if isAuth();
      allow delete: if isAuth();
    }

    // Wishlists
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Saved addresses
    match /user_addresses/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Payment preferences
    match /user_payments/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User behavior (AI recommendations)
    match /user_behavior/{userId} {
      allow read, write: if isOwner(userId);
    }

    // A/B testing
    match /ab_assignments/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /ab_results/{docId} {
      allow read, write: if isAuth();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
    }

    // Returns
    match /returns/{returnId} {
      allow read, create, update: if isAuth();
      match /messages/{msgId} {
        allow read, create: if isAuth();
      }
    }

    // Support tickets
    match /support_tickets/{ticketId} {
      allow read, create, update: if isAuth();
      match /messages/{msgId} {
        allow read, create: if isAuth();
      }
    }

    // Product Q&A
    match /product_qa/{questionId} {
      allow read: if true;
      allow create: if isAuth();
      match /answers/{answerId} {
        allow read: if true;
        allow create: if isAuth();
      }
    }

    // Daily deal — public read, authenticated write (admin uses client SDK)
    match /daily_deal/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Product presence
    match /product_presence/{productId} {
      allow read, write: if isAuth();
    }

    // Inventory — public read, authenticated write (admin dashboard uses client SDK)
    match /inventory/{productId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Products catalogue — public read, authenticated write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuth();
    }
  }
}
